# ============================================
# Zipsa - Configuration
# ============================================
# Copy to .env:
#   cp .env.example .env

# --- Local LLM (Ollama) ---
LOCAL_MODEL=qwen3.5:9b
LOCAL_HOST=http://localhost:11434
# In Docker: LOCAL_HOST=http://ollama:11434

# --- External Provider (required) ---
# Options: anthropic, gemini, openai
EXTERNAL_PROVIDER=anthropic

# --- API Keys ---
# ANTHROPIC_API_KEY=your-key
# GEMINI_API_KEY=your-key
# OPENAI_API_KEY=your-key

# --- Model overrides (optional) ---
# CLAUDE_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.0-flash

# --- OAuth (optional — enables browser-based auth) ---
# ANTHROPIC_OAUTH_CLIENT_ID=
# ANTHROPIC_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_BASE=http://localhost:8000
# TOKEN_ENCRYPTION_KEY=  # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Server ---
DEMO_MODE=true
LOG_DIR=logs
