# Required: path to llm-gateway/06_qa (stays local, never committed)
EVAL_DATA_DIR=/path/to/llm-gateway/06_qa

# Reuse existing zipsa settings — these should already be in your .env
# LOCAL_MODEL=qwen3.5:9b
# LOCAL_HOST=http://localhost:11434
# EXTERNAL_PROVIDER=anthropic
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: override cache location (default: eval/results/response_cache.json)
# EVAL_CACHE_PATH=/path/to/cache.json
